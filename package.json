{
  "name": "@adddog/monorepo-consistency",
  "version": "0.1.1",
  "type": "module",
  "bin": {
    "mono": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "types": "tsgo -p tsconfig.typecheck.json",
    "dev": "tsx src/cli.ts",
    "release": "bumpp --yes --no-push --no-tag --release patch",
    "generate-schema": "tsx scripts/generate-schema.ts",
    "prepack": "pnpm run build",
    "build:watch": "tsup --watch",
    "test": "vitest --watch=false",
    "knip": "knip",
    "version:patch": "npm version patch --no-git-tag-version"
  },
  "dependencies": {
    "@adddog/zod-to-json-schema": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dpdm": "^4.0.1",
    "fast-glob": "^3.3.3",
    "lodash": "^4.18.1",
    "madge": "^8.0.0",
    "minimatch": "^10.2.5",
    "ora": "^9.4.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/madge": "^5.0.3",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "beta",
    "@vitest/coverage-v8": "^4.1.5",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.1",
    "knip": "^6.9.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  },
  "bundledDeps": true,
  "peerDependencies": {
    "@vue/compiler-sfc": "^3.5.22"
  },
  "engines": {
    "node": ">= 22",
    "pnpm": ">= 10",
    "npm": ">= 11"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
}
